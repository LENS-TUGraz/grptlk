menuconfig GRPTLK
	bool "GRPTLK [EXPERIMENTAL]"
	select EXPERIMENTAL
	default n

if GRPTLK

choice GRPTLK_ROLE
    bool "GRPTLK Role"
    default GRPTLK_BCST

config GRPTLK_BCST
    bool "GRPTLK Broadcaster Role"

config GRPTLK_RECV
    bool "GRPTLK Receiver Role"

endchoice

endif # GRPTLK

config NRFX_I2S
	default y if GRPTLK

config NRFX_I2S0
	default y if GRPTLK

config NRFX_CLOCK
	default y if GRPTLK

source "Kconfig.zephyr"
