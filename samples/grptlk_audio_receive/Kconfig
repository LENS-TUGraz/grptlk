menuconfig GRPTLK
	bool "GRPTLK [EXPERIMENTAL]"
	select EXPERIMENTAL
	default n

if GRPTLK

choice GRPTLK_ROLE
	bool "GRPTLK Role"
	default GRPTLK_RECV

config GRPTLK_BCST
	bool "GRPTLK Broadcaster Role"

config GRPTLK_RECV
	bool "GRPTLK Receiver Role"

endchoice

config GRPTLK_NUM_CHAN
	int "Number of ISO channels (BISes)"
	default 5
	range 2 5
	help
	  Number of isochronous channels to support. Includes 1 downlink BIS
	  plus (n-1) uplink BISes for push-to-talk.

choice GRPTLK_AUDIO_FRAME_DURATION
	prompt "Audio frame duration"
	default GRPTLK_AUDIO_FRAME_10_MS
	help
	  5ms: LC3Plus custom format (32kbps = 20 bytes/frame)
	  10ms: BAP 16_2_1 compliant LC3 (32kbps = 40 bytes/frame)

config GRPTLK_AUDIO_FRAME_5_MS
	bool "5 ms (LC3Plus custom)"

config GRPTLK_AUDIO_FRAME_10_MS
	bool "10 ms (BAP 16_2_1 LC3)"

endchoice

choice GRPTLK_LC3_CODEC
	prompt "LC3 codec implementation"
	default GRPTLK_LC3_CODEC_OPEN if GRPTLK_AUDIO_FRAME_5_MS
	default GRPTLK_LC3_CODEC_T2 if GRPTLK_AUDIO_FRAME_10_MS

config GRPTLK_LC3_CODEC_OPEN
	bool "Open-source liblc3 (default)"
	help
	  Use the open-source liblc3 codec (CONFIG_LIBLC3).

config GRPTLK_LC3_CODEC_T2
	bool "T2 Software LC3"
	select SW_CODEC_LC3
	select SW_CODEC_LC3_T2_SOFTWARE
	help
	  Use T2 Software LC3 codec via Nordic's sw_codec_lc3 wrapper.
	  Requires FP_HARDABI support.

endchoice

if GRPTLK_LC3_CODEC_T2

config LC3_DEC_CHAN_MAX
	int
	default GRPTLK_NUM_CHAN

endif

choice GRPTLK_AUDIO_CODEC
	prompt "Hardware audio codec"
	default GRPTLK_AUDIO_CODEC_CIRRUS

config GRPTLK_AUDIO_CODEC_CIRRUS
	bool "Cirrus CS47L63"
	help
	  Use the nRF5340 Audio DK's onboard CS47L63 codec backend.

config GRPTLK_AUDIO_CODEC_MAX9867
	bool "MAX9867"
	help
	  Use the sample-local MAX9867 backend with the analog microphone
	  wired to MICRP. Build with FILE_SUFFIX=max9867 (or the legacy
	  FILE_SUFFIX=le_audio_playground alias) so the sample picks up the
	  external-codec devicetree overlay.

endchoice

config GRPTLK_DEBUG_GPIO
	bool "Enable debug GPIO pins for logic analyzer"
	default n
	depends on BOARD_NRF5340_AUDIO_DK_NRF5340_CPUAPP
	help
	  Enable 4 GPIO output pins for timing analysis with logic analyzer.
	  D2/P0.31 = ISO recv, D3/P1.0 = LC3 decode, D4/P1.1 = LC3 encode, P1.14 = ISO sent
	  Only works on nRF5340 Audio DK. Keep disabled for other platforms.

config GRPTLK_AUDIO_FRAME_DURATION_MS
	int
	default 5 if GRPTLK_AUDIO_FRAME_5_MS
	default 10 if GRPTLK_AUDIO_FRAME_10_MS

config GRPTLK_AUDIO_RING_NUM_BLKS
	int
	default 10 if GRPTLK_AUDIO_FRAME_5_MS
	default 16 if GRPTLK_AUDIO_FRAME_10_MS

config GRPTLK_RX_TARGET_PREFILL_BLKS
	int "Target playback ring fill before writing a decoded frame"
	default 2
	range 0 8
	help
	  The drift controller aims to keep roughly this many 1 ms playback
	  blocks in the ring just before the next decoded LC3 frame is written.
	  This keeps latency low while still leaving room for a whole frame.

config BT_ISO_TX_MTU
	default 24 if GRPTLK_AUDIO_FRAME_5_MS
	default 44 if GRPTLK_AUDIO_FRAME_10_MS

config NRFX_I2S
	default y

config NRFX_I2S0
	default y

config NRFX_CLOCK
	default y

config I2C
	default y if GRPTLK_AUDIO_CODEC_MAX9867

config I2C_NRFX
	default y if GRPTLK_AUDIO_CODEC_MAX9867

config NRFX_TWIM
	default y if GRPTLK_AUDIO_CODEC_MAX9867

config NRFX_TWIM1
	default y if GRPTLK_AUDIO_CODEC_MAX9867

config BT_ISO_MAX_CHAN
	int
	default GRPTLK_NUM_CHAN

config HW_CODEC_CIRRUS_LOGIC
	depends on GRPTLK_AUDIO_CODEC_CIRRUS
	default y if GRPTLK_AUDIO_CODEC_CIRRUS
	default n if GRPTLK_AUDIO_CODEC_MAX9867

config GRPTLK_UPLINK_BIS
	int "Static uplink BIS index (1-based, BIS1 is downlink)"
	default 2
	range 2 5
	help
	  BIS index on which this receiver transmits uplink audio back to the
	  broadcaster. BIS1 is always the downlink, so valid values are 2..5.
	  Only used when GRPTLK_UPLINK_RANDOM is disabled.

config GRPTLK_UPLINK_RANDOM
	bool "Randomly select uplink BIS each interval"
	default n
	help
	  When enabled the receiver picks a random uplink BIS (BIS2..BISn) on
	  every transmission interval instead of always using GRPTLK_UPLINK_BIS.
	  The broadcaster must use a single shared LC3 decoder for all uplink
	  BISes to handle the stream correctly.

config GRPTLK_UPLINK_RANDOM_PER_PTT
	bool "Randomly select uplink BIS once per PTT session"
	default y
	depends on !GRPTLK_UPLINK_RANDOM
	help
	  When enabled, the receiver picks a random uplink BIS (BIS2..BISn) when
	  PTT is pressed and uses that same BIS for the entire PTT session.
	  A new random BIS is selected each time PTT is released and pressed again.

config GRPTLK_AUDIO_SOURCE_LINE_IN
	bool "Boot with LINE-IN as audio source on CS47L63 builds"
	default y if BOARD_NRF5340_AUDIO_DK_NRF5340_CPUAPP && GRPTLK_AUDIO_CODEC_CIRRUS
	default n
	depends on BOARD_NRF5340_AUDIO_DK_NRF5340_CPUAPP && HW_CODEC_CIRRUS_LOGIC && \
		GRPTLK_AUDIO_CODEC_CIRRUS
	help
	  When enabled, the CS47L63 path prefers the 3.5 mm LINE-IN jack
	  (IN2L/IN2R) instead of the onboard digital microphone. Can be
	  overridden at runtime with BTN5. MAX9867 builds always use the
	  analog MICRP path and do not support source switching.

config GRPTLK_PTT_VAD
	bool "PTT VAD mode (long-press detection on PTT-lock button)"
	default y
	help
	  When enabled, the PTT-lock button (sw3) distinguishes short and long
	  presses. Short press (<800 ms) toggles PTT-lock as usual. Long press
	  (>=800 ms) toggles VAD mode (green LED) instead of toggling the lock.

if GRPTLK_PTT_VAD

config GRPTLK_VAD_AGGRESSIVENESS
	int "VAD aggressiveness (0=quality, 3=aggressive filtering)"
	default 2
	range 0 3
	help
	  Controls libfvad filtering mode. 0 preserves more speech at the cost
	  of more false triggers, 3 aggressively filters noise but may clip
	  quiet speech. 2 is a good default for noisy environments.

config GRPTLK_VAD_ONSET_FRAMES
	int "VAD onset frames (consecutive speech before TX activation)"
	default 3
	range 1 10
	help
	  Number of consecutive 10 ms speech frames required before the VOX
	  state machine activates PTT. Higher values reduce false triggers
	  but increase onset latency. 3 = 30 ms onset delay.

config GRPTLK_VAD_HANGOVER_FRAMES
	int "VAD hangover frames (silence before TX deactivation)"
	default 30
	range 5 100
	help
	  Number of consecutive 10 ms silence frames after last detected speech
	  before PTT is deactivated. Prevents TX from cutting off during
	  natural speech pauses. 30 = 300 ms hangover.

config GRPTLK_VAD_ENERGY_THRESHOLD
	int "VAD energy gate — minimum peak amplitude to consider speech"
	default 200
	range 0 10000
	help
	  Frames whose peak absolute sample value is below this threshold are
	  forced to silence regardless of what libfvad reports. Filters out
	  low-level background noise that the VAD algorithm still triggers on.
	  0 disables the energy gate. Typical mic noise floor is 50-150;
	  200 is a conservative default. Raise for noisier environments.

endif # GRPTLK_PTT_VAD

endif # GRPTLK

source "Kconfig.zephyr"
