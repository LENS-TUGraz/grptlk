menuconfig GRPTLK
	bool "GRPTLK [EXPERIMENTAL]"
	select EXPERIMENTAL
	default n

if GRPTLK

choice GRPTLK_ROLE
	bool "GRPTLK Role"
	default GRPTLK_BCST

config GRPTLK_BCST
	bool "GRPTLK Broadcaster Role"

config GRPTLK_RECV
	bool "GRPTLK Receiver Role"

endchoice

config GRPTLK_RELAY_ONLY
	bool "Audio Broadcast Relay Mode"
	default y if BT_BAP_BROADCAST_SRC_STREAM_COUNT = 2
	depends on BT_BAP_BROADCAST_SRC_STREAM_COUNT = 2
	help
	  When enabled, audio decoding, mixing, and the local microphone are disabled.
	  Incoming LC3 audio from the first RX BIS is relayed directly to the TX BIS.

choice GRPTLK_AUDIO_BACKEND
	bool "Audio Backend"
	default GRPTLK_AUDIO_BACKEND_CS47L63 if BOARD_NRF5340_AUDIO_DK_NRF5340_CPUAPP
	default GRPTLK_AUDIO_BACKEND_MAX9867

config GRPTLK_AUDIO_BACKEND_CS47L63
	bool "CS47L63 on nRF5340 Audio DK"
	help
	  Use the CS47L63 codec path used on nrf5340_audio_dk.

config GRPTLK_AUDIO_BACKEND_MAX9867
	bool "MAX9867 on HWN001 / nRF54L15"
	help
	  Use the MAX9867 codec path used on HWN001 and nRF54L15 targets.

endchoice

if GRPTLK_AUDIO_BACKEND_CS47L63

config NRFX_I2S
	default y

config NRFX_I2S0
	default y

config NRFX_CLOCK
	default y

config HW_CODEC_CIRRUS_LOGIC
	default y

endif # GRPTLK_AUDIO_BACKEND_CS47L63

rsource "src/drivers/Kconfig"

endif # GRPTLK

source "Kconfig.zephyr"
