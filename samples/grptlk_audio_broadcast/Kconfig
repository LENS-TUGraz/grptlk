menuconfig GRPTLK
	bool "GRPTLK [EXPERIMENTAL]"
	select EXPERIMENTAL
	default n

if GRPTLK

choice GRPTLK_ROLE
	bool "GRPTLK Role"
	default GRPTLK_BCST

config GRPTLK_BCST
	bool "GRPTLK Broadcaster Role"

config GRPTLK_RECV
	bool "GRPTLK Receiver Role"

endchoice

config GRPTLK_NUM_CHAN
	int "Number of ISO channels (BISes)"
	default 5
	range 2 5
	help
	  Number of isochronous channels to support. Includes 1 downlink BIS
	  plus (n-1) uplink BISes for push-to-talk.

choice GRPTLK_AUDIO_FRAME_DURATION
	prompt "Audio frame duration"
	default GRPTLK_AUDIO_FRAME_10_MS
	help
	  5ms: LC3Plus custom format (32kbps = 20 bytes/frame)
	  10ms: BAP 16_2_1 compliant LC3 (32kbps = 40 bytes/frame)

config GRPTLK_AUDIO_FRAME_5_MS
	bool "5 ms (LC3Plus custom)"

config GRPTLK_AUDIO_FRAME_10_MS
	bool "10 ms (BAP 16_2_1 LC3)"

endchoice

choice GRPTLK_LC3_CODEC
	prompt "LC3 codec implementation"
	default GRPTLK_LC3_CODEC_OPEN if GRPTLK_AUDIO_FRAME_5_MS
	default GRPTLK_LC3_CODEC_T2 if GRPTLK_AUDIO_FRAME_10_MS

config GRPTLK_LC3_CODEC_OPEN
	bool "Open-source liblc3 (default)"
	help
	  Use the open-source liblc3 codec (CONFIG_LIBLC3).

config GRPTLK_LC3_CODEC_T2
	bool "T2 Software LC3"
	select SW_CODEC_LC3
	select SW_CODEC_LC3_T2_SOFTWARE
	help
	  Use T2 Software LC3 codec via Nordic's sw_codec_lc3 wrapper.
	  Requires FP_HARDABI support.

endchoice

if GRPTLK_LC3_CODEC_T2

config LC3_DEC_CHAN_MAX
	int
	default GRPTLK_NUM_CHAN

endif

config GRPTLK_DEBUG_GPIO
	bool "Enable debug GPIO pins for logic analyzer"
	default n
	depends on BOARD_NRF5340_AUDIO_DK_NRF5340_CPUAPP
	help
	  Enable 4 GPIO output pins for timing analysis with logic analyzer.
	  D2/P0.31 = ISO recv, D3/P1.0 = LC3 decode, D4/P1.1 = LC3 encode, P1.14 = ISO sent
	  Only works on nRF5340 Audio DK. Keep disabled for other platforms.

config GRPTLK_INIT_LC3_CONSTANTLY
	bool "Experimental: reset uplink LC3 state on every valid packet"
	default n
	select LC3_PLC_DISABLED if GRPTLK_LC3_CODEC_T2
	help
		  Reinitialize the decoder state before every valid uplink decode so
		  that no LC3 history is carried across packets on a BIS.
		  Missed uplink packets are rendered as silence instead of invoking PLC.
		  This is intended to test whether decoder history is what breaks when
		  the receiver changes uplink BIS every interval.

config GRPTLK_AUDIO_FRAME_DURATION_MS
	int
	default 5 if GRPTLK_AUDIO_FRAME_5_MS
	default 10 if GRPTLK_AUDIO_FRAME_10_MS

config GRPTLK_AUDIO_RING_NUM_BLKS
	int
	default 8 if GRPTLK_AUDIO_FRAME_5_MS
	default 13 if GRPTLK_AUDIO_FRAME_10_MS

config GRPTLK_DOWNLINK_APPENDIX
	bool "Append 4-byte downlink ISO appendix"
	default n
	help
	  Append a 4-byte downlink application appendix after each LC3 frame in the
	  ISO SDU. This is used for the uplink BIS activity bitmap. Disable this to
	  send only raw LC3 payload bytes. Keep this aligned with the receiver
	  sample if both ends should use the same transport format.

config BT_ISO_TX_MTU
	default 24 if GRPTLK_AUDIO_FRAME_5_MS && GRPTLK_DOWNLINK_APPENDIX
	default 20 if GRPTLK_AUDIO_FRAME_5_MS
	default 44 if GRPTLK_AUDIO_FRAME_10_MS && GRPTLK_DOWNLINK_APPENDIX
	default 40 if GRPTLK_AUDIO_FRAME_10_MS

if HW_CODEC_CIRRUS_LOGIC

config GRPTLK_AUDIO_SOURCE_LINE_IN
	bool "Use 3.5mm line-in as audio source (instead of PDM mic)"
	default n
	depends on BOARD_NRF5340_AUDIO_DK_NRF5340_CPUAPP
	help
	  When enabled, configures the CS47L63 to capture audio from the
	  3.5mm analog line-in jack instead of the onboard PDM microphone.
	  Connect a line-level source to J5 on the nRF5340 Audio DK.

config NRFX_I2S
	default y

config NRFX_I2S0
	default y

config NRFX_CLOCK
	default y

config BT_ISO_MAX_CHAN
	int
	default GRPTLK_NUM_CHAN

config BT_BAP_BROADCAST_SRC_STREAM_COUNT
	int
	default GRPTLK_NUM_CHAN

endif # HW_CODEC_CIRRUS_LOGIC

endif # GRPTLK

source "Kconfig.zephyr"
